# ResuLink Environment Configuration

# The port the Go web server will listen on
PORT=8080

# The path to the SQLite database file
DB_PATH=resumes.db

# Cloudflare R2 Storage Credentials
# ----------------------------------------------------
# 1. Login to Cloudflare Dashboard
# 2. Go to R2 Object Storage > Manage R2 API Tokens
# 3. Create a token with read/write permissions
# 4. Copy the values below:

# Cloudflare Account ID (Found in R2 dashboard URL or Account Home)
R2_ACCOUNT_ID=your_cloudflare_account_id

# S3 Access Key ID (Generated with the API token)
R2_ACCESS_KEY_ID=your_r2_access_key_id

# S3 Secret Access Key (Generated with the API token)
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Name of the R2 bucket you created to store the resumes
R2_BUCKET_NAME=your_r2_bucket_name
